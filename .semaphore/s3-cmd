# s3-cmd: thin wrapper around s3cmd for Calico CI object storage. It replaces
# the `gcloud storage` / `gsutil` calls that previously cached build artifacts
# to, and restored them from, Google Cloud Storage.
#
# The S3 destination and credentials are configurable entirely through
# environment variables:
#
#   CALICO_S3_ACCESS_KEY   - S3 access key id              (required)
#   CALICO_S3_SECRET_KEY   - S3 secret access key          (required)
#   CALICO_S3_BUCKET       - destination bucket name       (required by callers
#                            that build s3:// URLs from it; not used directly
#                            here)
#   CALICO_S3_KEY_PREFIX   - key prefix within the bucket  (optional, used by
#                            callers when building s3:// URLs)
#   CALICO_S3_HOST         - S3 endpoint host base         (optional; default is
#                            s3cmd's built-in AWS endpoint)
#   CALICO_S3_HOST_BUCKET  - host-bucket template          (optional; defaults to
#                            "%(bucket)s.${CALICO_S3_HOST}" when a host is set)
#
# Callers refer to objects with s3:// URLs, typically via $S3_WORKFLOW_DIR or
# $S3_CACHE_DIR, which the Semaphore global job config builds from
# CALICO_S3_BUCKET / CALICO_S3_KEY_PREFIX.
#
# Usage mirrors the subset of `gcloud storage` that CI used:
#
#   s3-cmd cp [-r] <src>... <dst>   Upload (dst is an s3:// URL), download (the
#                                   single src is an s3:// URL) or server-side
#                                   copy (both are s3:// URLs). A trailing "/*"
#                                   on an s3:// source is treated as a recursive
#                                   fetch of that prefix (s3cmd has no glob).
#   s3-cmd ls <s3url>               List; exits non-zero when nothing matches, so
#                                   `if s3-cmd ls ...` behaves like `gcloud
#                                   storage ls`.
#   s3-cmd write-config <path>      Write an s3cmd config file built from the
#                                   environment, for shipping the credentials to
#                                   a remote test VM that runs s3cmd directly.

set -euo pipefail

# Assemble the common s3cmd flags (credentials and, optionally, a non-AWS
# endpoint) into the S3CMD_ARGS array.
build_s3cmd_args() {
  S3CMD_ARGS=(
    --no-progress
    "--access_key=${CALICO_S3_ACCESS_KEY:?CALICO_S3_ACCESS_KEY must be set}"
    "--secret_key=${CALICO_S3_SECRET_KEY:?CALICO_S3_SECRET_KEY must be set}"
  )
  if [[ -n "${CALICO_S3_HOST:-}" ]]; then
    S3CMD_ARGS+=(
      "--host=${CALICO_S3_HOST}"
      "--host-bucket=${CALICO_S3_HOST_BUCKET:-%(bucket)s.${CALICO_S3_HOST}}"
    )
  fi
}

is_s3() { [[ "$1" == s3://* ]]; }

cmd_cp() {
  local recursive=()
  while [[ "${1:-}" == -* ]]; do
    case "$1" in
      -r | -R | --recursive)
        recursive=(--recursive)
        shift
        ;;
      --)
        shift
        break
        ;;
      *)
        echo "s3-cmd cp: unknown flag $1" >&2
        exit 2
        ;;
    esac
  done

  if [[ $# -lt 2 ]]; then
    echo "s3-cmd cp: expected <src>... <dst>" >&2
    exit 2
  fi

  # The last argument is the destination; everything before it is a source.
  local dst="${*: -1}"
  local srcs=("${@:1:$#-1}")

  build_s3cmd_args

  if is_s3 "$dst"; then
    if is_s3 "${srcs[0]}"; then
      # Server-side copy (single source).
      s3cmd "${S3CMD_ARGS[@]}" cp "${recursive[@]}" "${srcs[0]}" "$dst"
    else
      # Upload one or more local sources.
      s3cmd "${S3CMD_ARGS[@]}" put "${recursive[@]}" "${srcs[@]}" "$dst"
    fi
  else
    # Download. s3cmd get has no wildcard support, so a trailing "/*" on the
    # source becomes a recursive fetch of the prefix.
    local src="${srcs[0]}"
    if [[ "$src" == */\* ]]; then
      src="${src%\*}"
      recursive=(--recursive)
    fi
    s3cmd "${S3CMD_ARGS[@]}" get --force "${recursive[@]}" "$src" "$dst"
  fi
}

cmd_ls() {
  build_s3cmd_args
  local out
  out="$(s3cmd "${S3CMD_ARGS[@]}" ls "$1")" || return 1
  [[ -n "$out" ]] || return 1
  printf '%s\n' "$out"
}

cmd_write_config() {
  local path="$1"
  local old_umask
  old_umask="$(umask)"
  umask 077
  {
    echo "[default]"
    echo "access_key = ${CALICO_S3_ACCESS_KEY:?CALICO_S3_ACCESS_KEY must be set}"
    echo "secret_key = ${CALICO_S3_SECRET_KEY:?CALICO_S3_SECRET_KEY must be set}"
    if [[ -n "${CALICO_S3_HOST:-}" ]]; then
      echo "host_base = ${CALICO_S3_HOST}"
      echo "host_bucket = ${CALICO_S3_HOST_BUCKET:-%(bucket)s.${CALICO_S3_HOST}}"
    fi
  } >"$path"
  umask "$old_umask"
}

case "${1:-}" in
  cp)
    shift
    cmd_cp "$@"
    ;;
  ls)
    shift
    cmd_ls "$@"
    ;;
  write-config)
    shift
    cmd_write_config "$@"
    ;;
  *)
    echo "usage: s3-cmd {cp [-r] <src>... <dst> | ls <s3url> | write-config <path>}" >&2
    exit 2
    ;;
esac
