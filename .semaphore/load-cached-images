#!/bin/bash

# Load pre-built docker images AND their build artifacts from GCS.
# See hack/cache-image-artifacts.sh for the corresponding store step: it
# snapshots every file the build wrote, so extracting those here restores
# the full Make prereq chain (binaries, LICENSEs, generated files, etc.)
# without hardcoding any paths.
#
# Also rehydrates calico/go-build from GCS. The global prologue loads it
# once per job, but blocks that run "docker system prune" (e.g. e2e) wipe
# it before the test commands run, which then cold-pulls from Docker Hub.

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)

"${REPO_ROOT}/hack/cache-image-artifacts.sh" load calico
"${REPO_ROOT}/hack/cache-image-artifacts.sh" load node
"${REPO_ROOT}/hack/cache-image-artifacts.sh" load whisker

# Reload calico/go-build if it's missing.
GO_BUILD_VER=$(grep -E '^GO_BUILD_VER[[:space:]]*=' "${REPO_ROOT}/metadata.mk" | cut -d'=' -f2 | tr -d '[:space:]')
image="calico/go-build:${GO_BUILD_VER}"
if ! docker image inspect "$image" >/dev/null 2>&1; then
    cache_path="gs://${GCS_BUILD_CACHE_BUCKET}/images/calico-go-build-${GO_BUILD_VER}.tar.zst"
    if gcloud storage cp "$cache_path" /tmp/go-build.tar.zst 2>/dev/null; then
        echo "Reloading ${image} from GCS cache"
        zstd -d --rm -o /tmp/go-build.tar /tmp/go-build.tar.zst
        docker load -i /tmp/go-build.tar
        rm -f /tmp/go-build.tar
    else
        echo "No GCS cache for ${image}, docker will pull from Docker Hub if needed"
    fi
fi
