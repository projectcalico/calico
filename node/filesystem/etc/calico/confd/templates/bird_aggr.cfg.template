   # Static routes needed for global BGP peers.
{{- end}}
   route {{$data.ip}}/128 via {{$data.reachable_by}};
{{- end}}
{{- end}}
{{- end}}
{{- if ls $node_peers_key_v6}}
{{- $run_once := true}}
{{- range gets (printf "%s/*" $node_peers_key_v6)}}{{$data := json .Value}}
{{- if and $data.ip $data.reachable_by}}
