# This script is run locally to push the FV test artifacts to our sub-directory
# in GCS. The counterpart to this script is load-test-artifacts, which runs on
# the test VM.  It can assume that the artifacts have been downloaded to /tmp.
#
# fv-artifacts are published to GCS (GCS_WORKFLOW_DIR) rather than the S3 build
# cache so the in-cloud GCP test VMs fetch them without cross-cloud egress. The
# source images, however, live on S3 (S3_WORKFLOW_DIR), published there by the
# "Build: *" prerequisite blocks, so this script bridges the two backends:
# `s3-cmd` (S3) to fetch, `gcloud storage` (GCS) to publish.

set -e
set -x

# Resolve the s3-cmd wrapper before we cd out of the component directory.
S3_CMD="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)/.semaphore/s3-cmd"

cd ../..

# Fetch pre-built images from the S3 workflow cache if available, and re-upload
# them into the GCS fv-artifacts directory for the test VM.
# These were built by the "Build: *" blocks in the Prerequisites stage.
for img in calico-image.tar.zst node-image.tar.zst whisker-image.tar.zst; do
  if "$S3_CMD" cp "${S3_WORKFLOW_DIR}/${img}" "/tmp/${img}" 2>/dev/null; then
    echo "Found pre-built ${img}, including in artifacts."
    gcloud storage cp "/tmp/${img}" "${GCS_WORKFLOW_DIR}/node/fv-artifacts/${img}"
  fi
done

tar -czf /tmp/working-copy.tgz \
  --exclude=${CALICO_DIR_NAME}/artifacts \
  ${CALICO_DIR_NAME}
gcloud storage cp /tmp/working-copy.tgz "${GCS_WORKFLOW_DIR}/node/fv-artifacts/"
